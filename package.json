{
  "name": "media-ingest",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "rimraf apps/*/dist packages/*/dist coverage",
    "cli:link-global": "pnpm build && pnpm --filter @media-ingest/cli exec npm link",
    "db:migrate": "tsx scripts/migrate.ts",
    "dev:api": "pnpm --filter @media-ingest/api dev",
    "cli": "pnpm --filter @media-ingest/cli cli",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  }
}
